{
  "name": "imaginary-creatures",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A DNA-splicing creature combiner + arena auto-battler, inspired by Impossible Creatures.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "vite build && node playtest.mjs",
    "verify": "npm run typecheck && npm test && npm run build && node playtest.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "playwright": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "three": "^0.160.1"
  }
}
